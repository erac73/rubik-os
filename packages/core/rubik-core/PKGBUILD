package() {
    # Orchestrator (same script installed as both rubikd and rubikctl)
    install -Dm755 "$srcdir/rubikd" "$pkgdir/usr/bin/rubikd"
    ln -sf /usr/bin/rubikd "$pkgdir/usr/bin/rubikctl"

    # Configuration
    install -Dm644 "$srcdir/cells.toml" "$pkgdir/etc/rubik/cells.toml"

    # Faces
    for face in 0 1 2 3 4 5; do
        install -Dm755 "$srcdir/face-${face}.sh" \
            "$pkgdir/usr/lib/rubik/faces/face-${face}.sh"
    done

    # Cells
    local cells=(memory-compression zram-udev oom-guard swap-manager hugepages
                 cache-tune cpu-gov mem-forecast cgroup-manager sched-tune initramfs
                 fs-layout cache-io dedup proxy-tun net-monitor bandwidth-limiter
                 wm-core bar-status launcher terminal compositor notifier wallpaper
                 clipboard idle-manager sandbox-exec crypto integrity firejail
                 update-auth cell-isolation
                 bluetooth pipewire display-manager wifi-manager)
    for cell in "${cells[@]}"; do
        install -Dm755 "$srcdir/${cell}.sh" \
            "$pkgdir/usr/lib/rubik/cells/${cell}.sh"
    done

    # Systemd services
    install -Dm644 "$srcdir/rubikd.service" \
        "$pkgdir/usr/lib/systemd/system/rubikd.service"
    install -Dm644 "$srcdir/rubik-cell@.service" \
        "$pkgdir/usr/lib/systemd/system/rubik-cell@.service"
    install -Dm644 "$srcdir/rubik-face@.service" \
        "$pkgdir/usr/lib/systemd/system/rubik-face@.service"
    install -Dm644 "$srcdir/rubik.target" \
        "$pkgdir/usr/lib/systemd/system/rubik.target"
    install -Dm644 "$srcdir/rubik-bluetooth.service" \
        "$pkgdir/usr/lib/systemd/system/rubik-bluetooth.service"
    install -Dm644 "$srcdir/rubik-pipewire.service" \
        "$pkgdir/usr/lib/systemd/system/rubik-pipewire.service"
    install -Dm644 "$srcdir/rubik-wireplumber.service" \
        "$pkgdir/usr/lib/systemd/system/rubik-wireplumber.service"
    install -Dm644 "$srcdir/rubik-wifi.service" \
        "$pkgdir/usr/lib/systemd/system/rubik-wifi.service"

    # Utility scripts
    install -Dm755 "$srcdir/rubik-configure" \
        "$pkgdir/usr/bin/rubik-configure"
    install -Dm755 "$srcdir/rubik-network" \
        "$pkgdir/usr/bin/rubik-network"
    install -Dm755 "$srcdir/rubik-recovery" \
        "$pkgdir/usr/bin/rubik-recovery"
    install -Dm755 "$srcdir/rubik-bench" \
        "$pkgdir/usr/bin/rubik-bench"
    install -Dm755 "$srcdir/rubik-boot" \
        "$pkgdir/usr/bin/rubik-boot"

    # AppArmor profiles
    install -Dm644 "$srcdir/rubik-cell.apparmor" \
        "$pkgdir/etc/apparmor.d/rubik/rubik-cell"
    install -Dm644 "$srcdir/rubik-cell-network.apparmor" \
        "$pkgdir/etc/apparmor.d/rubik/rubik-cell-network"
    install -Dm644 "$srcdir/rubik-cell-security.apparmor" \
        "$pkgdir/etc/apparmor.d/rubik/rubik-cell-security"

    # Logging
    install -Dm644 "$srcdir/30-rubik.conf" \
        "$pkgdir/etc/rsyslog.d/30-rubik.conf"
    install -Dm644 "$srcdir/rubik-logrotate" \
        "$pkgdir/etc/logrotate.d/rubik"

    # Sysctl
    install -Dm644 "$srcdir/90-rubik-memory.conf" \
        "$pkgdir/usr/lib/sysctl.d/90-rubik-memory.conf"
    install -Dm644 "$srcdir/99-rubik-security.conf" \
        "$pkgdir/usr/lib/sysctl.d/99-rubik-security.conf"

    # Documentation
    install -Dm644 "/rubik-os/README.md" \
        "$pkgdir/usr/share/doc/rubik/README.md"
}
