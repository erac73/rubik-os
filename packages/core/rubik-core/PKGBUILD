pkgname=rubik-core
pkgver=0.1.0
pkgrel=2
pkgdesc="Rubik OS core system — cell orchestrator and face definitions"
arch=('x86_64')
url="https://rubik-os.org"
license=('GPL3')
depends=(
    'bash'
    'systemd'
    'coreutils'
    'procps-ng'
    'gawk'
    'grep'
    'sed'
    'bc'
    'iproute2'
)
optdepends=(
    'earlyoom: OOM guard (F0.3)'
    'zram-generator: ZRAM management (F0.1)'
    'irqbalance: IRQ balancing (F0.6)'
    'chrony: NTP sync (F3.8)'
    'duperemove: Block dedup (F2.5)'
    'firejail: Sandboxing (F5.5)'
    'river: Wayland compositor (F4.0)'
    'waybar: Status bar (F4.1)'
    'rofi: Application launcher (F4.2)'
    'foot: Terminal emulator (F4.3)'
    'dunst: Notification daemon (F4.5)'
)
conflicts=()
replaces=()
source=(
