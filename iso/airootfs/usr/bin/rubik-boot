#!/usr/bin/env bash
# ───────────────────────────────────────────────
# rubik-boot — Bootloader helper for Rubik OS
# Handles GRUB installation and kernel param tuning
# ───────────────────────────────────────────────
set -euo pipefail

RUBIK_ROOT="${RUBIK_ROOT:-/usr/lib/rubik}"
GRUB_CFG="/etc/default/grub"

log()  { echo -e "\e[32m[✓]\e[0m $1"; }
warn() { echo -e "\e[33m[!]\e[0m $1"; }
err()  { echo -e "\e[31m[✗]\e[0m $1"; }

install_grub() {
    local disk="${1:-/dev/sda}"
    if ! command -v grub-install &>/dev/null; then
        err "grub-install not found"
        return 1
    fi
    grub-install --target=x86_64-efi --efi-directory=/boot --bootloader-id=RubikOS "$disk"
    grub-mkconfig -o /boot/grub/grub.cfg
    log "GRUB installed on $disk"
}

set_kernel_params() {
    local current
    if [[ -f "$GRUB_CFG" ]]; then
        current=$(grep "^GRUB_CMDLINE_LINUX_DEFAULT" "$GRUB_CFG" | sed 's/.*="//;s/"$//')
        if echo "$current" | grep -q "nowatchdog"; then
            warn "Kernel params already tuned"
            return 0
        fi
        sed -i 's/GRUB_CMDLINE_LINUX_DEFAULT=".*"/GRUB_CMDLINE_LINUX_DEFAULT="quiet splash nowatchdog mitigations=off zswap.enabled=0"/' "$GRUB_CFG"
        log "Kernel params set"
    fi
}

case "${1:-}" in
    install) install_grub "${2:-}" ;;
    params)  set_kernel_params ;;
    *)
        echo "Usage: rubik-boot {install [disk] | params}"
        echo "  install  Install GRUB to disk (default: /dev/sda)"
        echo "  params   Set optimal kernel parameters"
        ;;
esac
