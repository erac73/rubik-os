#!/usr/bin/env bash
# ───────────────────────────────────────────────
# rubik-install — Rubik OS Installer
# Interactive installer for Rubik OS
# ───────────────────────────────────────────────
set -euo pipefail

RED='\e[31m'; GREEN='\e[32m'; YELLOW='\e[33m'; CYAN='\e[36m'; BOLD='\e[1m'; NC='\e[0m'

log()   { echo -e "${GREEN}[✓]${NC} $1"; }
warn()  { echo -e "${YELLOW}[!]${NC} $1"; }
error() { echo -e "${RED}[✗]${NC} $1"; }
header(){ echo -e "\n${CYAN}══ $1 ══${NC}\n"; }

# ── Detect Hardware ────────────────────────────
detect_hardware() {
    header "Hardware Detection"

    local ram_kb
    ram_kb=$(awk '/MemTotal/{print $2}' /proc/meminfo)
    local ram_mb=$((ram_kb / 1024))

    local cpu_cores
    cpu_cores=$(nproc)

    local disk_size=""
    local disk_rotational=""

    # Find the main disk
    local main_disk=""
    for disk in /sys/block/sd? /sys/block/nvme?n? /sys/block/vd?; do
        if [[ -e "$disk" ]]; then
            main_disk=$(basename "$disk")
            disk_size=$(cat "/sys/block/$main_disk/size" 2>/dev/null || echo 0)
            disk_size=$((disk_size * 512 / 1024 / 1024 / 1024))  # Convert to GB
            if [[ -f "/sys/block/$main_disk/queue/rotational" ]]; then
                disk_rotational=$(cat "/sys/block/$main_disk/queue/rotational")
            fi
            break
        fi
    done

    local disk_type="HDD"
    [[ "$disk_rotational" == "0" ]] && disk_type="SSD"

    echo "  RAM:      ${ram_mb} MB"
    echo "  CPU:      ${cpu_cores} cores"
    echo "  Disk:     ${main_disk} — ${disk_size}GB (${disk_type})"
    echo ""
}

# ── Partition Disk ─────────────────────────────
DISK_DEV=""   # Global: set by partition_disk, used by format & mount

partition_disk() {
    header "Disk Partitioning"

    echo "  Available disks:"
    lsblk -d -o NAME,SIZE,TYPE,MOUNTPOINT | grep -v loop
    echo ""

    if [[ -z "$DISK_DEV" ]]; then
        read -rp "  Install to (e.g., /dev/sda): " DISK_DEV
    fi
    if [[ ! -b "$DISK_DEV" ]]; then
        error "Not a block device: $DISK_DEV"
        return 1
    fi

    if $NONINTERACTIVE; then
        warn "Installing to $DISK_DEV (non-interactive)"
    else
        warn "This will ERASE ALL DATA on $DISK_DEV"
        read -rp "  Continue? (yes/no): " confirm
        [[ "$confirm" != "yes" ]] && { error "Aborted"; return 1; }
    fi

    log "Partitioning $DISK_DEV..."

    # Create partition table (GPT)
    parted -s "$DISK_DEV" mklabel gpt

    # EFI partition (512MB)
    parted -s "$DISK_DEV" mkpart primary fat32 1MiB 513MiB
    parted -s "$DISK_DEV" set 1 esp on

    # Boot partition (1GB)
    parted -s "$DISK_DEV" mkpart primary ext4 513MiB 1537MiB

    # Root partition (remaining)
    parted -s "$DISK_DEV" mkpart primary btrfs 1537MiB 100%

    log "Partitioning complete"
}

# ── Partition suffix helper ─────────────────────
_part_suffix() {
    local dev="$DISK_DEV" num="$1"
    if echo "$dev" | grep -q "nvme"; then
        echo "${dev}p${num}"
    else
        echo "${dev}${num}"
    fi
}

# ── Format Filesystems ─────────────────────────
format_filesystems() {
    header "Formatting Filesystems"

    local efi_part=$(_part_suffix 1)
    local boot_part=$(_part_suffix 2)
    local root_part=$(_part_suffix 3)

    log "Formatting EFI partition ($efi_part)..."
    mkfs.fat -F32 "$efi_part"

    log "Formatting boot partition ($boot_part)..."
    mkfs.ext4 -F "$boot_part"

    log "Formatting root partition ($root_part) with LUKS..."
    cryptsetup luksFormat --type luks2 --cipher aes-xts-plain64 --key-size 512 "$root_part"
    cryptsetup open "$root_part" rubik-root

    log "Creating Btrfs filesystem..."
    mkfs.btrfs -f -L rubik-root /dev/mapper/rubik-root

    log "Formatting complete"
}

# ── Create Btrfs Subvolumes ────────────────────
create_subvolumes() {
    header "Creating Btrfs Subvolumes"

    mount /dev/mapper/rubik-root /mnt

    btrfs subvolume create /mnt/@
    btrfs subvolume create /mnt/@home
    btrfs subvolume create /mnt/@log
    btrfs subvolume create /mnt/@cache
    btrfs subvolume create /mnt/@snapshots

    umount /mnt

    log "Subvolumes created"
}

# ── Mount Partitions ───────────────────────────
mount_partitions() {
    header "Mounting Partitions"

    local efi_part=$(_part_suffix 1)
    local boot_part=$(_part_suffix 2)

    mount -o noatime,compress=zstd:3,space_cache=v2,subvol=@ /dev/mapper/rubik-root /mnt

    mkdir -p /mnt/{boot,home,var/log,var/cache,.snapshots}
    mkdir -p /mnt/boot/efi

    mount "$boot_part" /mnt/boot
    mount "$efi_part" /mnt/boot/efi
    mount -o noatime,compress=zstd:3,subvol=@home /dev/mapper/rubik-root /mnt/home
    mount -o noatime,compress=zstd:1,subvol=@log /dev/mapper/rubik-root /mnt/var/log
    mount -o noatime,compress=zstd:1,subvol=@cache /dev/mapper/rubik-root /mnt/var/cache
    mount -o subvol=@snapshots /dev/mapper/rubik-root /mnt/.snapshots

    log "Partitions mounted"
}

# ── Install Base System ────────────────────────
install_base() {
    header "Installing Rubik OS Base"

    # Install base packages
    pacstrap -K /mnt base base-devel linux-lts linux-firmware \
        grub efibootmgr btrfs-progs \
        networkmanager iwd nftables chrony \
        sudo git vim zram-generator \
        openssh rsyslog apparmor audit

    log "Base system installed"
}

# ── Configure System ───────────────────────────
configure_system() {
    header "Configuring System"

    # Generate fstab
    genfstab -U /mnt >> /mnt/etc/fstab

    # Get username before chroot
    if $NONINTERACTIVE; then
        INSTALL_USER="rubik"
    elif [[ -z "$INSTALL_USER" ]]; then
        read -rp "Username: " INSTALL_USER
    fi

    # Chroot and configure
    arch-chroot /mnt /bin/bash << CHROOT
        # Timezone
        ln -sf /usr/share/zoneinfo/UTC /etc/localtime
        hwclock --systohc

        # Locale
        echo "en_US.UTF-8 UTF-8" >> /etc/locale.gen
        locale-gen
        echo "LANG=en_US.UTF-8" > /etc/locale.conf

        # Hostname
        echo "rubik" > /etc/hostname

        # Root password
        echo "Set root password:"
        passwd

        # Create user
        useradd -m -G wheel "$INSTALL_USER"
        echo "Set password for $INSTALL_USER:"
        passwd "$INSTALL_USER"
        echo "%wheel ALL=(ALL:ALL) ALL" >> /etc/sudoers

        # Bootloader
        grub-install --target=x86_64-efi --efi-directory=/boot/efi --bootloader-id=RubikOS
        grub-mkconfig -o /boot/grub/grub.cfg

        # Enable services
        systemctl enable systemd-networkd
        systemctl enable systemd-resolved
        systemctl enable iwd
        systemctl enable nftables
        systemctl enable chronyd
        systemctl enable rubikd
        systemctl enable apparmor
        systemctl enable auditd
        systemctl enable rsyslog

        # Copy Rubik OS configuration
        cp -r /usr/share/rubik/* /etc/rubik/
CHROOT

    log "System configured"
}

# ── Non-interactive mode ────────────────────────
NONINTERACTIVE=false
DISK_DEV=""
INSTALL_USER=""

parse_args() {
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --yes|-y) NONINTERACTIVE=true ;;
            --disk=*) DISK_DEV="${1#*=}" ;;
            --help|-h)
                echo "Usage: rubik-install [--yes] [--disk=/dev/sda]"
                exit 0
                ;;
        esac
        shift
    done
}

# ── Validation ─────────────────────────────────
validate_environment() {
    header "Validating Environment"
    local errors=0

    if [[ $EUID -ne 0 ]]; then
        error "Must be run as root"
        errors=$((errors + 1))
    fi

    for cmd in parted mkfs.fat mkfs.ext4 cryptsetup mkfs.btrfs btrfs pacstrap genfstab arch-chroot; do
        if ! command -v "$cmd" &>/dev/null; then
            warn "Missing: $cmd"
            errors=$((errors + 1))
        fi
    done

    if [[ ! -f /usr/share/archiso/configs/releng/pacman.conf ]]; then
        warn "archiso configs not found — ISO build may fail"
    fi

    if [[ $errors -eq 0 ]]; then
        log "Environment OK"
    else
        warn "$errors prerequisite(s) missing"
    fi
    return $errors
}

# ── Summary ────────────────────────────────────
print_summary() {
    header "Installation Summary"
    echo "  Disk:         $DISK_DEV"
    echo "  Partitioning: GPT (EFI + Boot + LUKS/Btrfs)"
    echo "  Compress:     zstd:3 (root, home)"
    echo "  Kernel:       linux-lts (safety)"
    echo "  User:         $INSTALL_USER"
    echo ""
    echo "  Post-install:"
    echo "    1. Reboot into Rubik OS"
    echo "    2. Run: rubikctl bootstrap"
    echo "    3. Customize cells: rubikctl cell start <name>"
    echo "    4. Benchmark: rubik-bench all"
    echo ""
}

# ── Main ───────────────────────────────────────
main() {
    parse_args "$@"

    cat << "EOF"
╔═══════════════════════════════════════════╗
║       Rubik OS Installer v0.1             ║
║    Optimized. Decentralized. Efficient.   ║
╚═══════════════════════════════════════════╝
EOF

    validate_environment || warn "Environment validation had warnings"
    detect_hardware
    if $NONINTERACTIVE && [[ -n "$DISK_DEV" ]]; then
        log "Non-interactive mode: installing to $DISK_DEV"
    fi
    partition_disk
    format_filesystems
    create_subvolumes
    mount_partitions
    install_base
    configure_system
    print_summary

    header "Installation Complete"
    echo "  Rubik OS has been installed."
    echo "  Reboot and remove the installation media."
    echo ""

    read -rp "  Reboot now? (yes/no): " reboot
    if [[ "$reboot" == "yes" ]]; then
        umount -R /mnt
        reboot
    fi
}

main "$@"
