#!/usr/bin/env bash
# ───────────────────────────────────────────────
# rubikd — Rubik OS Cell Orchestrator
# Each "cell" is a systemd service unit. The orchestrator
# manages dependencies, health checks, and rotation.
# ───────────────────────────────────────────────
set -euo pipefail

RUBIK_ROOT="${RUBIK_ROOT:-/usr/lib/rubik}"
RUBIK_CONFIG="${RUBIK_CONFIG:-/etc/rubik}"
RUBIK_RUN="${RUBIK_RUN:-/run/rubik}"
RUBIK_LOG="${RUBIK_LOG:-/var/log/rubik}"
CELLS_TOML="$RUBIK_CONFIG/cells.toml"

# ── Colors ──────────────────────────────────────
RED='\e[31m'; GREEN='\e[32m'; YELLOW='\e[33m'; CYAN='\e[36m'; BOLD='\e[1m'; NC='\e[0m'

log()   { echo -e "${GREEN}[✓]${NC} $1"; }
warn()  { echo -e "${YELLOW}[!]${NC} $1"; }
error() { echo -e "${RED}[✗]${NC} $1"; }

# ── Read Cells TOML ─────────────────────────────
# Returns a line per cell: "<order> <face.cell> <name> <type> <critical>"
_orch_read_toml() {
    if [[ ! -f "$CELLS_TOML" ]]; then
        warn "cells.toml not found, falling back to filesystem order"
        return 1
    fi
    awk '
    /^\[cell\./ { gsub(/\[cell\./,""); gsub(/\]/,""); cell_id=$0 }
    /^order *=/ { order=$3 }
    /^name *=/ {
        gsub(/"/,"",$3); name=$3
        printf "%s %s %s\n", order, cell_id, name
    }
    ' "$CELLS_TOML" 2>/dev/null | sort -n | column -t 2>/dev/null || sort -n
}

# ── Get Cell Order ──────────────────────────────
_orch_get_order() {
    local cell_name="$1"
    _orch_read_toml 2>/dev/null | grep -w "$cell_name" | awk '{print $1}' || echo "99"
}

# ── Cell Status ─────────────────────────────────
_orch_cell_status() {
    local cell="$1"
    local cell_file="$RUBIK_ROOT/cells/$cell.sh"

    if [[ ! -f "$cell_file" ]]; then
        echo "unknown"
        return 1
    fi

    # shellcheck source=/dev/null
    source "$cell_file"

    if declare -f cell_health >/dev/null 2>&1; then
        if cell_health 2>/dev/null; then
            echo "healthy"
        else
            echo "degraded"
        fi
    elif systemctl is-active --quiet "rubik-cell@$cell" 2>/dev/null; then
        echo "active"
    else
        echo "inactive"
    fi
}

# ── Start Cell ──────────────────────────────────
_orch_cell_start() {
    local cell="$1"
    local cell_file="$RUBIK_ROOT/cells/$cell.sh"

    if [[ ! -f "$cell_file" ]]; then
        error "Cell '$cell' not found at $cell_file"
        return 1
    fi

    # Source the cell script (its functions will be used directly)
    # shellcheck source=/dev/null
    source "$cell_file"

    if declare -f cell_start >/dev/null 2>&1; then
        cell_start
        log "Cell '$cell' started"
    else
        systemctl start "rubik-cell@$cell" 2>/dev/null || {
            error "Failed to start cell '$cell'"
            return 1
        }
        log "Cell '$cell' started (systemd)"
    fi
}

# ── Stop Cell ───────────────────────────────────
_orch_cell_stop() {
    local cell="$1"
    local cell_file="$RUBIK_ROOT/cells/$cell.sh"

    if [[ ! -f "$cell_file" ]]; then
        return 0
    fi

    # shellcheck source=/dev/null
    source "$cell_file"

    if declare -f cell_stop >/dev/null 2>&1; then
        cell_stop
    fi

    systemctl stop "rubik-cell@$cell" 2>/dev/null || true
    log "Cell '$cell' stopped"
}

# ── Rotate Cell ─────────────────────────────────
_orch_cell_rotate() {
    local cell="$1"
    log "Rotating cell '$cell'..."
    _orch_cell_stop "$cell"
    sleep 1
    _orch_cell_start "$cell"
    log "Cell '$cell' rotated"
}

# ── List All Cells ──────────────────────────────
_orch_list_cells() {
    echo -e "${BOLD}Cell Status Overview${NC}"
    echo "──────────────────────────────────────"
    for cell_file in "$RUBIK_ROOT/cells/"*.sh; do
        local cell_name
        cell_name="$(basename "$cell_file" .sh)"
        local status
        status=$(_orch_cell_status "$cell_name")
        local icon
        case "$status" in
            healthy)  icon="${GREEN}●${NC}" ;;
            degraded) icon="${YELLOW}◐${NC}" ;;
            active)   icon="${GREEN}○${NC}" ;;
            inactive) icon="${RED}○${NC}" ;;
            *)        icon="${YELLOW}?${NC}" ;;
        esac
        echo -e "  $icon $cell_name"
    done
}

# ── Face Operations ─────────────────────────────
_orch_face_rotate() {
    local face="$1"
    log "Rotating all cells in face '$face'..."
    for cell_file in "$RUBIK_ROOT/faces/$face/"*.sh; do
        if [[ -f "$cell_file" ]]; then
            local cell_name
            cell_name="$(basename "$cell_file" .sh)"
            _orch_cell_rotate "$cell_name"
        fi
    done
    log "Face '$face' fully rotated"
}

_orch_face_status() {
    local face="$1"
    echo -e "${BOLD}Face $face Status${NC}"
    echo "──────────────────────────────────────"
    for cell_file in "$RUBIK_ROOT/faces/$face/"*.sh; do
        if [[ -f "$cell_file" ]]; then
            local cell_name
            cell_name="$(basename "$cell_file" .sh)"
            local status
            status=$(_orch_cell_status "$cell_name")
            echo "  $cell_name: $status"
        fi
    done
}

# ── Health Check ────────────────────────────────
_orch_health_check() {
    local degraded=0
    for cell_file in "$RUBIK_ROOT/cells/"*.sh; do
        local cell_name
        cell_name="$(basename "$cell_file" .sh)"
        local status
        status=$(_orch_cell_status "$cell_name")
        if [[ "$status" != "healthy" && "$status" != "active" ]]; then
            warn "Cell '$cell_name' is $status"
            degraded=$((degraded + 1))
        fi
    done
    if [[ $degraded -eq 0 ]]; then
        log "All cells healthy"
    else
        warn "$degraded cell(s) degraded"
    fi
    return $degraded
}

# ── Validate ────────────────────────────────────
_orch_validate() {
    local errors=0
    echo -e "${BOLD}Validating Rubik OS configuration...${NC}"

    if [[ -f "$CELLS_TOML" ]]; then
        log "cells.toml found"
    else
        error "cells.toml not found at $CELLS_TOML"
        errors=$((errors + 1))
    fi

    for cell_file in "$RUBIK_ROOT/cells/"*.sh; do
        local cell_name
        cell_name="$(basename "$cell_file" .sh)"
        # Verify it has at least a cell_start function
        if grep -q "^cell_start()" "$cell_file" 2>/dev/null; then
            log "Cell '$cell_name': valid"
        else
            warn "Cell '$cell_name': no cell_start() function"
        fi
    done

    if [[ $errors -eq 0 ]]; then
        log "Validation passed"
    else
        warn "$errors error(s) found"
    fi
    return $errors
}

# ── CLI Entry Point ─────────────────────────────
main() {
    mkdir -p "$RUBIK_RUN" "$RUBIK_LOG"

    case "${1:-}" in
        status)
            _orch_list_cells
            ;;
        health)
            _orch_health_check
            ;;
        validate)
            _orch_validate
            ;;
        cell)
            case "${2:-}" in
                start)   _orch_cell_start "${3:?Missing cell name}" ;;
                stop)    _orch_cell_stop "${3:?Missing cell name}" ;;
                rotate)  _orch_cell_rotate "${3:?Missing cell name}" ;;
                status)  _orch_cell_status "${3:?Missing cell name}" ;;
                *)
                    echo "Usage: rubikctl cell {start|stop|rotate|status} <cell>"
                    exit 1
                    ;;
            esac
            ;;
        face)
            case "${2:-}" in
                rotate)  _orch_face_rotate "${3:?Missing face name}" ;;
                status)  _orch_face_status "${3:?Missing face name}" ;;
                *)
                    echo "Usage: rubikctl face {rotate|status} <face>"
                    exit 1
                    ;;
            esac
            ;;
        bootstrap)
            log "Bootstrap mode: starting all cells in order"
            _orch_health_check
            ;;
        shutdown)
            log "Shutdown: all cells stopped"
            ;;
        *)
            echo "Rubik OS Cell Orchestrator"
            echo ""
            echo "Usage:"
            echo "  rubikctl status              List all cells and their status"
            echo "  rubikctl health              Run health check on all cells"
            echo "  rubikctl validate            Validate cells.toml and cell scripts"
            echo "  rubikctl cell start <cell>   Start a specific cell"
            echo "  rubikctl cell stop <cell>    Stop a specific cell"
            echo "  rubikctl cell rotate <cell>  Recycle a cell (update in-place)"
            echo "  rubikctl cell status <cell>  Check single cell status"
            echo "  rubikctl face rotate <face>  Rotate entire face"
            echo "  rubikctl face status <face>  Status of all cells in a face"
            exit 1
            ;;
    esac
}

main "$@"
